# Variables requeridas por el gate de acceso (middleware.ts + api/gate.ts).
# Configuralas en Vercel: Dashboard → Project → Settings → Environment Variables.
# NUNCA commitees el .env real con valores productivos.

# Token que el usuario debe ingresar en el formulario de acceso.
GATE_TOKEN=presi2026

# Secreto usado para firmar la cookie (HMAC-SHA256). Si alguien consigue este
# secreto puede forjar cookies válidas. Genera uno aleatorio largo:
#   openssl rand -hex 32
# o
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GATE_SECRET=CAMBIAR_POR_UN_HEX_ALEATORIO_DE_64_CARACTERES
